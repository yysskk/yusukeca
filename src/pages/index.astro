---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yusuke Morishita" description="Yusuke Morishita - Software Engineer, Mobile. Based in North Vancouver, BC, Canada.">
  <div class="page-home">
    <main class="card">
      <h1 class="name">Yusuke Morishita</h1>
      <p class="title">Software Engineer, Mobile</p>
      <p class="location">North Vancouver, BC, Canada</p>

      <div class="divider"></div>

      <div class="section">
        <h2 class="section-label">Objective</h2>
        <p class="bio">
          Mobile engineer with 9+ years of experience. Expert in Swift/Objective-C, cross-platform in Kotlin and Flutter.
        </p>
      </div>

      <div class="section">
        <h2 class="section-label">Career</h2>
        <ul class="experience-list">
          <li class="experience-item">
            <div>
              <div class="experience-company">SmartNews</div>
              <div class="experience-role">Tech Lead, iOS/Android</div>
            </div>
            <span class="experience-period">2020 &ndash; 2024</span>
          </li>
          <li class="experience-item">
            <div>
              <div class="experience-company">CyberAgent</div>
              <div class="experience-role">Software Engineer, iOS</div>
            </div>
            <span class="experience-period">2017 &ndash; 2020</span>
          </li>
        </ul>
      </div>

      <div class="section">
        <h2 class="section-label">Open Source</h2>
        <ul class="oss-list">
          <li class="oss-item">
            <a href="https://github.com/yysskk/SwipeMenuViewController" target="_blank" rel="noopener noreferrer">SwipeMenuViewController</a>
            <div class="oss-desc">Swipable tab and menu UI for iOS</div>
          </li>
          <li class="oss-item">
            <a href="https://github.com/nicklama/swift-nostr-client" target="_blank" rel="noopener noreferrer">swift-nostr-client</a>
            <div class="oss-desc">Nostr protocol client in Swift</div>
          </li>
          <li class="oss-item">
            <a href="https://github.com/nicklama/swift-mockable" target="_blank" rel="noopener noreferrer">swift-mockable</a>
            <div class="oss-desc">Mock generation for Swift testing</div>
          </li>
        </ul>
      </div>

      <div class="section">
        <h2 class="section-label">Skills</h2>
        <div class="skills-list">
          <span class="skill-tag">Swift</span>
          <span class="skill-tag">SwiftUI</span>
          <span class="skill-tag">Objective-C</span>
          <span class="skill-tag">Kotlin</span>
          <span class="skill-tag">Flutter</span>
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">Next.js</span>
          <span class="skill-tag">React</span>
        </div>
      </div>

      <div class="social-links">
        <a href="mailto:hello@yusuke.ca" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/yusukeca/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://github.com/yysskk" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </main>
  </div>
</BaseLayout>
